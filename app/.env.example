SLACK_WEBHOOK_URL= #paste your slack url
AI_GAP_ALERT_THRESHOLD=5 # threshold count to trigger notification in slack
AI_CONFIDENCE_THRESHOLD=0.75 # ticket is resolved when confidence >= this value
AI_UNRESOLVED_THRESHOLD=0.45 # ticket is unresolved when confidence < this value
RAG_DISTANCE_NORMALIZER=2500 # larger values increase retrieval_score from FAISS distances
RAG_CONTEXT_MIN_SCORE=0.2 # minimum top similarity to treat KB context as found